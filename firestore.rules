rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (
          request.auth.token.email_verified == true && (
            request.auth.token.email == "sanjaykatkuri2004@gmail.com" ||
            request.auth.token.email == "nithish0504@gmail.com"
          )
        )
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Metadata / Test document
    match /test/connection {
      allow read: if true;
    }

    // PassengerStatus rules
    match /passengerStatuses/{statusId} {
      function isValidStatus(data) {
        return data.passengerId is string && data.passengerId.size() <= 64 &&
               data.journeyId is string && data.journeyId.size() <= 32 &&
               data.status in ['pending', 'onboarded', 'left-out', 'present', 'coming'] &&
               data.updatedAt is timestamp;
      }

      allow get, list: if true; // Everyone can see the live status
      
      allow create: if (isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/guestMappings/$(request.auth.uid)).data.passengerId == incoming().passengerId)) &&
                      isValidId(statusId) &&
                      isValidStatus(incoming()) &&
                      incoming().updatedAt == request.time;
                      
      allow update: if (isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/guestMappings/$(request.auth.uid)).data.passengerId == existing().passengerId)) &&
                      isValidStatus(incoming()) &&
                      incoming().updatedAt == request.time &&
                      incoming().passengerId == existing().passengerId &&
                      incoming().journeyId == existing().journeyId &&
                      (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'updatedBy']));
    }

    // Notification rules
    match /notifications/{notifId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }

    // Guest Mapping rules
    match /guestMappings/{uid} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // Admin rules (read-only for security, only manually updated or via safe logic)
    match /admins/{adminUid} {
      allow read: if isSignedIn();
    }
  }
}
